{
  "id": "shinden_ultimate",
  "name": "Shinden.pl (pełny)",
  "version": "2.0.0",
  "description": "Shinden.pl z logowaniem, resolverem API i cache.",
  "baseUrl": "https://shinden.pl",
  "language": "pl",
  "types": ["movies", "series"],
  "nsfw": false,
  "priority": 10,
  "enabledByDefault": true,
  "cf": true,
  "category": "portal",
  "moduleType": "scraper",
  "runtime": { "enabled": true },

  "settings": [
    { "key": "username", "label": "Login", "type": "text", "required": true, "placeholder": "Nazwa użytkownika", "group": "Konto" },
    { "key": "password", "label": "Hasło", "type": "password", "required": true, "sensitive": true, "group": "Konto" }
  ],

  "auth": {
    "type": "login",
    "webviewLogin": true,
    "loginUrl": "/main/0/login",
    "usernameField": "username",
    "passwordField": "password",
    "formSelector": "form[action*='/login']",
    "successCookie": "PHPSESSID",
    "username": "{settings.username}",
    "password": "{settings.password}",
    "fields": { "login": "" },
    "csrf": { "url": "/", "selector": "input[name=_token] | attr:value", "field": "_token" },
    "verify": { "url": "/", "loggedIn": "Wyloguj" }
  },

  "search": {
    "url": "/series",
    "method": "GET",
    "params": { "search": "{title}" },
    "headers": {
      "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
      "Accept-Language": "pl,en-US;q=0.9,en;q=0.8",
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36"
    },
    "responseType": "html",
    "resultSelector": {
      "container": "li.desc-col:has(a[href*=\"/series/\"])",
      "fields": {
        "title": "a | text",
        "url": "a[href] | href",
        "year": "a | text",
        "thumbnail": "img | src"
      }
    }
  },

  "matching": {
    "titleField": "title",
    "yearField": "year",
    "urlField": "url",
    "yearTolerance": 1,
    "scoring": { "minScore": 55 }
  },

  "detail": {
    "url": "{result.url}",
    "headers": {
      "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
      "Accept-Language": "pl,en-US;q=0.9,en;q=0.8",
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36"
    }
  },

  "episode": {
    "url": "{result.url}/all-episodes",
    "container": "tbody.list-episode-checkboxes tr",
    "urlField": "a[href] | href",
    "labelField": "td:nth-child(2) | text",
    "pattern": "(\\d+)",
    "cache": { "ttl": 86400 }
  },

  "sources": {
    "extract": [
      {
        "type": "css",
        "selector": "section.episode-player-list tr",
        "fields": {
          "host": "td:nth-child(1) | text",
          "quality": "td:nth-child(2) | text",
          "audio": "td:nth-child(3) span.mobile-hidden | text",
          "subs": "td:nth-child(4) span.mobile-hidden | text",
          "vidId": "td:nth-child(6) | regex:data_(\\d+)",
          "authCode": "script | regex:_Storage\\.basic.*=.*'([^']+)'"
        }
      }
    ],
    "transform": [
      {
        "field": "url",
        "type": "concat",
        "prefix": "shinden-lazy://resolve?vidId={vidId}&auth={authCode}&page={result.url}"
      },
      {
        "field": "quality",
        "type": "map",
        "values": { "1080": "1080p", "720": "720p", "480": "480p" },
        "default": "AUTO"
      },
      {
        "field": "language",
        "type": "map",
        "values": { "Polski": "pl", "English": "en" },
        "default": "pl"
      }
    ],
    "output": {
      "url": "{url}",
      "hosting": "{host}",
      "quality": "{quality}",
      "language": "{language}",
      "type": "pl",
      "direct": false,
      "canPlay": false
    }
  },

  "resolver": {
    "type": "lazy",
    "steps": [
      {
        "step": 1,
        "description": "Pobierz cookies i przygotuj sesję",
        "method": "GET",
        "url": "{page}",
        "headers": { "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36" },
        "extract": { "type": "cookies", "field": "cookies" }
      },
      {
        "step": 2,
        "description": "Zamień player_load na player_show i pobierz finalny iframe",
        "method": "GET",
        "url": "https://api4.shinden.pl/xhr/{vidId}/player_show?auth={auth}&width=508",
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36",
          "Cookie": "{cookies}"
        },
        "responseType": "html",
        "extract": [
          { "type": "css", "selector": "iframe", "attr": "src", "field": "iframeUrl" },
          { "type": "css", "selector": "a", "attr": "href", "field": "linkUrl" }
        ],
        "transform": [
          {
            "field": "finalUrl",
            "type": "first",
            "sources": ["iframeUrl", "linkUrl"]
          },
          {
            "field": "finalUrl",
            "type": "regexReplace",
            "pattern": "^//",
            "replacement": "https:"
          }
        ]
      }
    ],
    "output": {
      "url": "{finalUrl}",
      "direct": true
    }
  },

  "cache": {
    "session": { "ttl": 604800 },
    "episodes": { "ttl": 86400 },
    "searchResults": { "ttl": 86400 }
  },

  "errorDetection": [
    {
      "id": "cloudflare",
      "detectIn": "body",
      "contains": "cf-browser-verification",
      "response": {
        "error": "CLOUDFLARE_CHALLENGE",
        "message": "Wymagane rozwiązanie Cloudflare.",
        "requiresWebView": true,
        "url": "{baseUrl}"
      }
    },
    {
      "id": "login_required",
      "detectIn": "body",
      "contains": "Zaloguj się",
      "response": {
        "error": "LOGIN_REQUIRED",
        "message": "Wymagane zalogowanie na shinden.pl.",
        "requiresWebView": true,
        "url": "{baseUrl}/"
      }
    },
    {
      "id": "rate_limit",
      "detectIn": "headers",
      "statusCode": 429,
      "response": {
        "error": "RATE_LIMIT",
        "message": "Przekroczono limit zapytań. Spróbuj później.",
        "retryAfter": "{Retry-After}"
      }
    }
  ]
}
