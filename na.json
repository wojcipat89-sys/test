{
  "id": "naszeanime_lazy",
  "name": "NaszeAnime.pl (Lazy)",
  "version": "1.0.0",
  "description": "Scraper lazy-resolve dla naszeanime.pl. Wyszukuje przez API, listuje odcinki, zwraca link do resolwera.",
  "baseUrl": "https://naszeanime.pl",
  "language": "pl",
  "types": ["movies", "series"],
  "nsfw": false,
  "priority": 30,
  "enabledByDefault": true,
  "cf": true,
  "category": "portal",
  "moduleType": "scraper",
  "runtime": { "enabled": true },

  "search": {
    "url": "/api/trpc/anime.search?batch=1",
    "method": "GET",
    "params": {
      "input": "{ \"0\": { \"json\": { \"query\": \"{title}\" } } }"
    },
    "headers": {
      "Accept": "application/jsonl, */*",
      "Accept-Language": "pl,en-US;q=0.9,en;q=0.8",
      "Referer": "{baseUrl}/",
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36",
      "trpc-accept": "application/jsonl",
      "x-trpc-source": "nextjs-react"
    },
    "responseType": "json",
    "resultSelector": {
      "type": "jsonPath",
      "path": "$.result.data.json.items[*]",
      "fields": {
        "title": "title",
        "handle": "handle",
        "year": "year",
        "thumbnail": "poster",
        "id": "id"
      }
    },
    "transform": [
      {
        "field": "url",
        "type": "concat",
        "prefix": "/anime/",
        "suffix": ""
      },
      {
        "field": "thumbnail",
        "type": "concat",
        "prefix": "https://cdn.naszeanime.pl/anime/",
        "suffix": "/thumbnail.webp"
      }
    ]
  },

  "matching": {
    "titleField": "title",
    "yearField": "year",
    "urlField": "url",
    "yearTolerance": 1,
    "scoring": { "minScore": 55 }
  },

  "detail": {
    "url": "{result.url}",
    "headers": {
      "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
      "Accept-Language": "pl,en-US;q=0.9,en;q=0.8",
      "Referer": "{baseUrl}/",
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36"
    },
    "responseType": "html"
  },

  "episode": {
    "url": "{result.url}",
    "container": "ul.episode-list a[href*=\"/watch?epId=\"], div.episodes a[href*=\"/watch?epId=\"]",
    "urlField": "| href",
    "labelField": "| text",
    "pattern": "epId=(\\d+)"
  },

  "sources": {
    "extract": [
      {
        "type": "regex",
        "pattern": "epId=(\\d+)",
        "fields": { "episodeId": 1 }
      }
    ],
    "transform": [
      {
        "field": "episodeId",
        "type": "regexReplace",
        "pattern": ".*",
        "replacement": "naszeanime-lazy://resolve?episodeId={episodeId}&anime={result.url}"
      }
    ],
    "output": {
      "url": "{episodeId}",
      "hosting": "naszeanime.pl",
      "version": "Lazy",
      "quality": "AUTO",
      "type": "pl",
      "language": "pl",
      "direct": false,
      "canPlay": false,
      "description": "Wymaga rozwiązania przez zewnętrzny resolver."
    }
  },

  "errorDetection": [
    {
      "id": "cloudflare",
      "detectIn": "body",
      "contains": "cf-browser-verification",
      "response": {
        "error": "CLOUDFLARE_CHALLENGE",
        "message": "Wymagane rozwiązanie Cloudflare.",
        "requiresWebView": true,
        "url": "{baseUrl}"
      }
    }
  ]
}
