{
  "id": "naszeanime_api",
  "name": "NaszeAnime.pl (API)",
  "version": "2.0.0",
  "description": "Scraper wykorzystujący API tRPC i HTML. Wyszukuje, listuje odcinki i wyciąga embed playerów.",
  "baseUrl": "https://naszeanime.pl",
  "language": "pl",
  "types": ["movies", "series"],
  "nsfw": false,
  "priority": 30,
  "enabledByDefault": true,
  "cf": true,
  "category": "portal",
  "moduleType": "scraper",
  "runtime": { "enabled": true },

  "search": {
    "url": "/api/trpc/anime.search?batch=1",
    "method": "GET",
    "params": {
      "input": "{ \"0\": { \"json\": { \"query\": \"{title}\" } } }"
    },
    "headers": {
      "Accept": "application/jsonl, */*",
      "Accept-Language": "pl,en-US;q=0.9,en;q=0.8",
      "Referer": "{baseUrl}/",
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36",
      "trpc-accept": "application/jsonl",
      "x-trpc-source": "nextjs-react"
    },
    "responseType": "json",
    "resultSelector": {
      "type": "jsonPath",
      "path": "$.result.data.json.items[*]",
      "fields": {
        "title": "title",
        "url": "handle",
        "year": "year",
        "thumbnail": "poster",
        "animeId": "id"
      }
    },
    "transform": [
      {
        "field": "url",
        "type": "concat",
        "prefix": "/anime/",
        "suffix": ""
      },
      {
        "field": "thumbnail",
        "type": "concat",
        "prefix": "https://cdn.naszeanime.pl/anime/",
        "suffix": "/thumbnail.webp"
      }
    ]
  },

  "matching": {
    "titleField": "title",
    "yearField": "year",
    "urlField": "url",
    "yearTolerance": 1,
    "scoring": { "minScore": 55 }
  },

  "detail": {
    "url": "{result.url}",
    "headers": {
      "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
      "Accept-Language": "pl,en-US;q=0.9,en;q=0.8",
      "Referer": "{baseUrl}/",
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36"
    },
    "responseType": "html"
  },

  "episode": {
    "url": "{result.url}",
    "container": "ul.episode-list a[href*=\"/watch?epId=\"], div.episodes a[href*=\"/watch?epId=\"]",
    "urlField": "| href",
    "labelField": "| text",
    "pattern": "epId=(\\d+)"
  },

  "sources": {
    "extract": [
      {
        "type": "regex",
        "pattern": "epId=(\\d+)",
        "fields": { "episodeId": 1 }
      }
    ],
    "output": {
      "url": "naszeanime-lazy://resolve?episodeId={episodeId}&anime={result.url}",
      "hosting": "naszeanime.pl",
      "version": "API",
      "quality": "AUTO",
      "type": "pl",
      "language": "pl",
      "direct": false,
      "canPlay": false,
      "description": "Wymaga rozpoznania odcinka przez resolver (pobranie graczy)."
    }
  },

  "resolver": {
    "type": "api",
    "endpoint": "/anime/{anime}/get-episode-streams",
    "params": {
      "epId": "{episodeId}",
      "playerId": "{playerId}"
    },
    "headers": {
      "Accept": "*/*",
      "Accept-Language": "pl,en-US;q=0.9,en;q=0.8",
      "Referer": "{baseUrl}/anime/{anime}/watch?epId={episodeId}",
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36"
    },
    "prefetch": [
      {
        "url": "/api/trpc/anime.player.getPlayers?batch=1",
        "method": "GET",
        "params": {
          "input": "{ \"0\": { \"json\": { \"episodeId\": {episodeId} } } }"
        },
        "responseType": "jsonl",
        "extract": {
          "type": "jsonPath",
          "path": "$.result.data.json.players[*]",
          "fields": {
            "playerId": "id",
            "name": "name"
          }
        }
      },
      {
        "url": "/api/trpc/anime.player.getPlayerEmbedUrl?batch=1",
        "method": "GET",
        "params": {
          "input": "{ \"0\": { \"json\": { \"playerId\": {playerId} } } }"
        },
        "responseType": "jsonl",
        "extract": {
          "type": "jsonPath",
          "path": "$.result.data.json.url",
          "fields": {
            "embedUrl": "$"
          }
        },
        "output": {
          "url": "{embedUrl}",
          "hosting": "player",
          "version": "embed",
          "quality": "AUTO",
          "type": "pl",
          "language": "pl",
          "direct": false,
          "canPlay": false
        }
      }
    ]
  },

  "errorDetection": [
    {
      "id": "cloudflare",
      "detectIn": "body",
      "contains": "cf-browser-verification",
      "response": {
        "error": "CLOUDFLARE_CHALLENGE",
        "message": "Wymagane rozwiązanie Cloudflare.",
        "requiresWebView": true,
        "url": "{baseUrl}"
      }
    },
    {
      "id": "login_required",
      "detectIn": "body",
      "contains": "Zaloguj się",
      "response": {
        "error": "LOGIN_REQUIRED",
        "message": "Wymagane zalogowanie na naszeanime.pl.",
        "requiresWebView": true,
        "url": "{baseUrl}/auth/login"
      }
    }
  ]
}
